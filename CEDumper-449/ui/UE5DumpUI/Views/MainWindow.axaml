<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UE5DumpUI.ViewModels"
        xmlns:views="using:UE5DumpUI.Views"
        x:Class="UE5DumpUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/Mainicon.ico"
        Title="{Binding WindowTitle}" Background="#1E1E1E"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="500">

  <DockPanel>
    <!-- Top Toolbar (WrapPanel for adaptive layout) -->
    <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,4">
      <WrapPanel Orientation="Horizontal">

        <!-- Connection buttons + status -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" Margin="0,2">
          <Button Content="{StaticResource str.Connect}"
                  Command="{Binding ConnectCommand}"
                  IsVisible="{Binding !IsConnected}"
                  ToolTip.Tip="{StaticResource str.Tip.Connect}"
                  Classes="accent" Padding="12,4"/>
          <Button Content="{StaticResource str.Disconnect}"
                  Command="{Binding DisconnectCommand}"
                  IsVisible="{Binding IsConnected}"
                  ToolTip.Tip="{StaticResource str.Tip.Disconnect}"
                  Padding="12,4"/>
          <Button Content="{StaticResource str.Toolbar.StartScan}"
                  Command="{Binding TriggerScanCommand}"
                  IsVisible="{Binding NeedsScan}"
                  IsEnabled="{Binding !IsScanning}"
                  ToolTip.Tip="{StaticResource str.Tip.StartScan}"
                  Classes="accent" Padding="12,4"
                  FontWeight="Bold"/>
          <TextBlock Text="{Binding StatusText}"
                     Foreground="#4EC9B0"
                     VerticalAlignment="Center"
                     Margin="4,0"/>
          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="#F44747"
                     VerticalAlignment="Center"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- Address format selector -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" Margin="8,2">
          <TextBlock Text="{StaticResource str.Toolbar.AddressFormat}"
                     Foreground="#CCCCCC" FontSize="12"
                     VerticalAlignment="Center"/>
          <ComboBox ItemsSource="{Binding AddressFormatOptions}"
                    SelectedIndex="{Binding SelectedAddressFormatIndex}"
                    ToolTip.Tip="{StaticResource str.Tip.AddressFormat}"
                    MinWidth="140" Padding="4,2" FontSize="12"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <!-- CE XML collapse toggle -->
        <CheckBox Content="{StaticResource str.Toolbar.CollapsePointers}"
                  IsChecked="{Binding CollapsePointerNodes}"
                  ToolTip.Tip="{StaticResource str.Tip.CollapsePointers}"
                  Foreground="#CCCCCC" FontSize="12"
                  VerticalAlignment="Center" Margin="8,2"/>

        <!-- Array Limit slider group -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" Margin="8,2">
          <TextBlock Text="{StaticResource str.Toolbar.ArrayLimit}"
                     Foreground="#CCCCCC" FontSize="12"
                     VerticalAlignment="Center"/>
          <Slider Value="{Binding ArrayLimitExponent}"
                  Minimum="1" Maximum="14"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  Width="140"
                  ToolTip.Tip="{StaticResource str.Tip.ArrayLimit}"
                  VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ArrayLimit}"
                     Foreground="#D4D4D4" FontSize="12" FontWeight="Bold"
                     VerticalAlignment="Center" MinWidth="35"/>
          <TextBlock Text="{StaticResource str.Toolbar.ArrayLimitWarn}"
                     Foreground="#F4A747" FontSize="11"
                     VerticalAlignment="Center"
                     IsVisible="{Binding ShowArrayLimitWarning}"/>
        </StackPanel>

        <!-- DropDown Limit slider group -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" Margin="8,2">
          <TextBlock Text="{StaticResource str.Toolbar.DropDownLimit}"
                     Foreground="#CCCCCC" FontSize="12"
                     VerticalAlignment="Center"/>
          <Slider Value="{Binding DropDownLimitExponent}"
                  Minimum="6" Maximum="13"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  Width="100"
                  ToolTip.Tip="{StaticResource str.Tip.DropDownLimit}"
                  VerticalAlignment="Center"/>
          <TextBlock Text="{Binding DropDownLimit}"
                     Foreground="#D4D4D4" FontSize="12" FontWeight="Bold"
                     VerticalAlignment="Center" MinWidth="35"/>
        </StackPanel>

        <!-- Preview limit slider group -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" Margin="8,2">
          <TextBlock Text="{StaticResource str.Toolbar.PreviewLimit}"
                     Foreground="#CCCCCC" FontSize="12"
                     VerticalAlignment="Center"/>
          <Slider Value="{Binding PreviewLimit}"
                  Minimum="0" Maximum="6"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  Width="100"
                  ToolTip.Tip="{StaticResource str.Tip.PreviewLimit}"
                  VerticalAlignment="Center"/>
          <TextBlock Text="{Binding PreviewLimit}"
                     Foreground="#D4D4D4" FontSize="12" FontWeight="Bold"
                     VerticalAlignment="Center" MinWidth="15"/>
        </StackPanel>

        <!-- CSX Depth slider group -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" Margin="8,2">
          <TextBlock Text="{StaticResource str.Toolbar.CsxDepth}"
                     Foreground="#CCCCCC" FontSize="12"
                     VerticalAlignment="Center"/>
          <Slider Value="{Binding CsxDrilldownDepth}"
                  Minimum="0" Maximum="4"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  Width="80"
                  ToolTip.Tip="{StaticResource str.Tip.CsxDepth}"
                  VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CsxDrilldownDepth}"
                     Foreground="#D4D4D4" FontSize="12" FontWeight="Bold"
                     VerticalAlignment="Center" MinWidth="15"/>
        </StackPanel>

        <!-- Export dropdown -->
        <Border Margin="8,2" VerticalAlignment="Center"
                IsVisible="{Binding IsConnected}">
          <DropDownButton Content="{StaticResource str.Toolbar.Export}"
                          ToolTip.Tip="{StaticResource str.Tip.Export}"
                          Padding="8,3" FontSize="12">
            <DropDownButton.Flyout>
              <MenuFlyout>
                <MenuItem Header="{StaticResource str.Export.SymbolsX64dbg}"
                          Command="{Binding ExportSymbolsX64dbgCommand}"/>
                <MenuItem Header="{StaticResource str.Export.SymbolsGhidra}"
                          Command="{Binding ExportSymbolsGhidraCommand}"/>
                <MenuItem Header="{StaticResource str.Export.SymbolsIda}"
                          Command="{Binding ExportSymbolsIdaCommand}"/>
                <Separator/>
                <MenuItem Header="{StaticResource str.Export.SdkHeader}"
                          Command="{Binding ExportFullSdkCommand}"/>
                <MenuItem Header="{StaticResource str.Export.Usmap}"
                          Command="{Binding ExportUsmapCommand}"/>
              </MenuFlyout>
            </DropDownButton.Flyout>
          </DropDownButton>
        </Border>

        <!-- Version label -->
        <TextBlock Text="{Binding AppVersion}"
                   Foreground="#808080" FontSize="11"
                   VerticalAlignment="Center" Margin="8,2"/>
      </WrapPanel>
    </Border>

    <!-- Main Content: Left Tree + Right Tabs -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="350" MinWidth="200"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Object Tree -->
      <views:ObjectTreePanel Grid.Column="0" DataContext="{Binding ObjectTree}"/>

      <GridSplitter Grid.Column="1" Background="#3C3C3C"
                    ResizeDirection="Columns"/>

      <!-- Right: Tab panels -->
      <TabControl x:Name="MainTabs" Grid.Column="2" Background="#1E1E1E" Padding="4"
                  SelectedIndex="{Binding SelectedTabIndex}"
                  SelectionChanged="MainTabs_SelectionChanged">
        <TabItem Header="{StaticResource str.Tab.LiveWalker}">
          <views:LiveWalkerPanel DataContext="{Binding LiveWalker}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.InstanceFinder}">
          <views:InstanceFinderPanel DataContext="{Binding InstanceFinder}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.PropertySearch}">
          <views:PropertySearchPanel DataContext="{Binding PropertySearch}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.GameClassFilter}">
          <views:GameClassFilterPanel DataContext="{Binding GameClassFilter}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.ClassStruct}">
          <views:ClassStructPanel DataContext="{Binding ClassStruct}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.Pointers}">
          <views:PointerPanel DataContext="{Binding Pointers}"/>
        </TabItem>
        <TabItem Header="{StaticResource str.Tab.ProxyDeploy}">
          <views:ProxyDeployPanel DataContext="{Binding ProxyDeploy}"/>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
